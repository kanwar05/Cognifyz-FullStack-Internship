<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="shell">
    <section class="header">
      <div>
        <p class="eyebrow">Advanced Express</p>
        <h1>Middleware, Caching, Logging, and Jobs</h1>
      </div>
      <button id="jobButton">Create Background Job</button>
    </section>
    <section class="grid">
      <article class="panel">
        <h2>Cached Server Stats</h2>
        <button id="statsButton">Refresh Stats</button>
        <pre id="statsOutput">No stats loaded.</pre>
      </article>
      <article class="panel">
        <h2>Background Jobs</h2>
        <div id="jobsOutput">No jobs yet.</div>
      </article>
    </section>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
