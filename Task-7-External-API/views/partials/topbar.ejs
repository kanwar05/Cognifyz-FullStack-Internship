<header class="topbar">
  <button class="icon-btn d-lg-none" type="button" data-sidebar-toggle aria-label="Open navigation">
    <i class="bi bi-list"></i>
  </button>

  <div>
    <p class="page-kicker">Cognifyz Full Stack Internship</p>
    <h1><%= title %></h1>
  </div>

  <div class="topbar-actions">
    <button class="icon-btn" type="button" data-theme-toggle aria-label="Toggle theme">
      <i class="bi bi-moon-stars"></i>
    </button>
    <div class="profile-chip">
      <span class="avatar">FS</span>
      <span>
        <strong>Full Stack Intern</strong>
        <small>Portfolio Mode</small>
      </span>
    </div>
  </div>
</header>
