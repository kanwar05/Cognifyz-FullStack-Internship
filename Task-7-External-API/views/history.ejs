<%- include('partials/head') %>
<%- include('partials/sidebar') %>

<main class="main-content">
  <%- include('partials/topbar') %>

  <section class="panel reveal">
    <div class="panel-header">
      <div>
        <span class="mini-label">Last 10 searches</span>
        <h3>Timeline</h3>
      </div>
      <a href="/explorer" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Search</a>
    </div>

    <% if (history.length) { %>
      <div class="timeline">
        <% history.forEach((item) => { %>
          <article class="timeline-item">
            <div class="timeline-dot"></div>
            <div>
              <span class="status-pill"><%= item.status %></span>
              <h4><%= item.city %>, <%= item.country %></h4>
              <p><%= item.temperature %>&deg; recorded at <%= new Date(item.createdAt).toLocaleString() %></p>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i class="bi bi-clock-history"></i>
        <h3>No search history yet.</h3>
        <p>Your last 10 weather searches will appear here after you use the explorer.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include('partials/scripts') %>
