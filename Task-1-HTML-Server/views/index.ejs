<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="page">
    <section class="panel">
      <p class="eyebrow">Cognifyz Internship</p>
      <h1>Basic HTML Form Server</h1>
      <p><%= objective %></p>
      <form action="/submit" method="POST">
        <label for="name">Full Name</label>
        <input id="name" type="text" name="name" placeholder="Aarav Sharma" required>
        <label for="email">Email Address</label>
        <input id="email" type="email" name="email" placeholder="aarav@example.com" required>
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="4" placeholder="Write a short message..." required></textarea>
        <button type="submit">Submit Form</button>
      </form>
    </section>
  </main>
</body>
</html>
