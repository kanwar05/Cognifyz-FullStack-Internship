<%- include('partials/header') %>

<main class="auth-page container py-5">
  <div class="auth-card mx-auto">
    <h1>Login</h1>
    <p class="text-muted">Access your personal task dashboard.</p>

    <% if (errors.length) { %>
      <div class="alert alert-danger">
        <% errors.forEach((error) => { %>
          <div><%= error %></div>
        <% }) %>
      </div>
    <% } %>

    <form id="loginForm" action="/login" method="POST" novalidate>
      <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input class="form-control" id="email" type="email" name="email" value="<%= form.email || '' %>" required>
        <div class="invalid-feedback">Enter your email address.</div>
      </div>
      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input class="form-control" id="password" type="password" name="password" required>
        <div class="invalid-feedback">Enter your password.</div>
      </div>
      <button class="btn btn-primary w-100" type="submit">Login</button>
    </form>
  </div>
</main>

<script src="/js/auth.js"></script>
<%- include('partials/footer') %>
