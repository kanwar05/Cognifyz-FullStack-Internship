<%- include('partials/header') %>

<main class="dashboard-page">
  <section class="dashboard-header py-4">
    <div class="container">
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
          <p class="eyebrow text-primary">Welcome, <%= currentUser.name %></p>
          <h1>Your Study Dashboard</h1>
        </div>
        <div id="quoteBox" class="quote-box">Loading quote...</div>
      </div>
    </div>
  </section>

  <section class="container pb-5">
    <div class="tab-buttons mb-4" role="tablist">
      <button class="tab-button active" data-tab="tasks">Tasks</button>
      <button class="tab-button" data-tab="create">Create</button>
      <button class="tab-button" data-tab="summary">Summary</button>
    </div>

    <div class="tab-panel active" id="tasksPanel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title">Task Cards</h2>
        <button id="refreshTasks" class="btn btn-outline-primary btn-sm">Refresh</button>
      </div>
      <div id="taskErrors" class="alert alert-danger d-none"></div>
      <div id="taskList" class="task-grid"></div>
    </div>

    <div class="tab-panel" id="createPanel">
      <form id="taskForm" class="task-form">
        <input type="hidden" id="taskId">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label" for="title">Task Title</label>
            <input class="form-control" id="title" name="title" required minlength="3">
            <div class="invalid-feedback">Title must be at least 3 characters.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label" for="priority">Priority</label>
            <select class="form-select" id="priority" name="priority">
              <option>Low</option>
              <option selected>Medium</option>
              <option>High</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label" for="status">Status</label>
            <select class="form-select" id="status" name="status">
              <option>Pending</option>
              <option>In Progress</option>
              <option>Completed</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label" for="dueDate">Due Date</label>
            <input class="form-control" id="dueDate" name="dueDate" type="date" required>
            <div class="invalid-feedback">Choose a valid due date.</div>
          </div>
          <div class="col-md-8">
            <label class="form-label" for="description">Description</label>
            <textarea class="form-control" id="description" name="description" rows="3" maxlength="500"></textarea>
          </div>
        </div>
        <div class="d-flex gap-2 mt-3">
          <button id="saveTaskBtn" class="btn btn-primary" type="submit">Save Task</button>
          <button id="resetTaskBtn" class="btn btn-outline-secondary" type="button">Clear</button>
        </div>
      </form>
    </div>

    <div class="tab-panel" id="summaryPanel">
      <div class="summary-grid">
        <div class="summary-card"><span id="totalCount">0</span><p>Total</p></div>
        <div class="summary-card"><span id="pendingCount">0</span><p>Pending</p></div>
        <div class="summary-card"><span id="completedCount">0</span><p>Completed</p></div>
      </div>
    </div>
  </section>
</main>

<script src="/js/dashboard.js"></script>
<%- include('partials/footer') %>
