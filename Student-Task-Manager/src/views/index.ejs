<%- include('partials/header') %>

<main>
  <section class="hero-section">
    <div class="container hero-content">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <p class="eyebrow">Cognifyz Full Stack Internship Project</p>
          <h1>Student Task Manager</h1>
          <p class="lead">Plan coursework, track priorities, and manage study deadlines from one responsive full-stack dashboard.</p>
          <div class="d-flex flex-wrap gap-2">
            <% if (currentUser) { %>
              <a href="/dashboard" class="btn btn-light btn-lg">Open Dashboard</a>
            <% } else { %>
              <a href="/register" class="btn btn-light btn-lg">Create Account</a>
              <a href="/login" class="btn btn-outline-light btn-lg">Login</a>
            <% } %>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="hero-panel">
            <div class="mini-card">
              <span class="badge text-bg-warning">High</span>
              <strong>Submit DB assignment</strong>
              <small>Due today</small>
            </div>
            <div class="mini-card">
              <span class="badge text-bg-success">Low</span>
              <strong>Read API notes</strong>
              <small>In progress</small>
            </div>
            <div class="mini-card">
              <span class="badge text-bg-info">Medium</span>
              <strong>Revise Express routes</strong>
              <small>Pending</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container py-5">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card">
          <h2>Secure Tasks</h2>
          <p>Every task belongs to the logged-in student and is protected by session authentication.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <h2>Live Dashboard</h2>
          <p>The task list updates with fetch requests, client validation, and dynamic form feedback.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <h2>Advanced Backend</h2>
          <p>Includes MongoDB, REST APIs, rate limiting, logging, caching, and global error handling.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
