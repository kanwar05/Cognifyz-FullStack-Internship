<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="app-shell">
    <nav class="tabs" aria-label="Form tabs">
      <button class="tab active" data-route="account">Account</button>
      <button class="tab" data-route="profile">Profile</button>
      <button class="tab" data-route="summary">Summary</button>
    </nav>

    <section class="panel">
      <form id="signupForm">
        <div class="route active" id="account">
          <h1>Account Details</h1>
          <label>Email</label>
          <input id="email" name="email" type="email" autocomplete="email">
          <p class="error" data-error-for="email"></p>

          <label>Password</label>
          <input id="password" name="password" type="password" autocomplete="new-password">
          <meter id="strengthMeter" min="0" max="4" value="0"></meter>
          <p id="strengthText">Password strength: empty</p>
          <p class="error" data-error-for="password"></p>

          <label>Confirm Password</label>
          <input id="confirmPassword" name="confirmPassword" type="password">
          <p class="error" data-error-for="confirmPassword"></p>
        </div>

        <div class="route" id="profile">
          <h1>Profile Preferences</h1>
          <label>Full Name</label>
          <input id="name" name="name" type="text">
          <p class="error" data-error-for="name"></p>

          <label>Skill Track</label>
          <select id="track" name="track">
            <option value="">Choose track</option>
            <option>Frontend</option>
            <option>Backend</option>
            <option>Full Stack</option>
          </select>
          <p class="error" data-error-for="track"></p>

          <label class="check"><input id="terms" name="terms" type="checkbox"> I accept the internship guidelines</label>
          <p class="error" data-error-for="terms"></p>
        </div>

        <div class="route" id="summary">
          <h1>Live Summary</h1>
          <div id="summaryBox" class="summary-box"></div>
          <button type="submit">Submit Client Form</button>
        </div>
      </form>
    </section>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
