<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <!-- Bootstrap is served locally from node_modules. -->
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top app-navbar">
    <div class="container">
      <a class="navbar-brand fw-bold" href="#/home">Task 4</a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNavbar"
        aria-controls="mainNavbar"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav ms-auto gap-lg-2">
          <li class="nav-item"><a class="nav-link route-link" href="#/home">Home</a></li>
          <li class="nav-item"><a class="nav-link route-link" href="#/form">Form</a></li>
          <li class="nav-item"><a class="nav-link route-link" href="#/preview">Preview</a></li>
          <li class="nav-item"><a class="nav-link route-link" href="#/success">Success</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <!-- Home route -->
    <section class="route-section hero-section active" id="home" data-route="home">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-lg-6 fade-slide">
            <span class="section-label">Complex Form Validation</span>
            <h1 class="display-4 fw-bold mt-3">Validate smarter forms with live DOM updates.</h1>
            <p class="lead mt-3">
              This Express and EJS project uses JavaScript to validate fields, update previews,
              track password strength, and show success without refreshing the page.
            </p>
            <div class="d-flex flex-column flex-sm-row gap-3 mt-4">
              <a class="btn btn-primary btn-lg app-btn" href="#/form">Start Registration</a>
              <a class="btn btn-outline-light btn-lg app-btn-outline" href="#/preview">View Preview</a>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="hero-card fade-slide delay-1">
              <div class="hero-card-row">
                <span>Live validation</span>
                <strong id="heroValidStatus">Pending</strong>
              </div>
              <div class="hero-meter">
                <span id="heroMeterFill"></span>
              </div>
              <div class="hero-mini-grid">
                <div>Name</div>
                <div>Email</div>
                <div>Password</div>
                <div>Skills</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Form route -->
    <section class="route-section section-padding" id="form" data-route="form">
      <div class="container">
        <div class="row justify-content-center text-center mb-4">
          <div class="col-lg-8">
            <span class="section-label">Registration Form</span>
            <h2 class="section-title mt-2">Create your learner profile</h2>
            <p class="section-text">Each field validates as you type and updates the preview card instantly.</p>
          </div>
        </div>

        <form id="registrationForm" class="form-card" novalidate>
          <div class="row g-4">
            <div class="col-md-6">
              <label for="fullName" class="form-label">Full Name</label>
              <input type="text" class="form-control" id="fullName" name="fullName" placeholder="Enter full name">
              <div class="validation-message" data-error-for="fullName"></div>
            </div>

            <div class="col-md-6">
              <label for="email" class="form-label">Email</label>
              <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com">
              <div class="validation-message" data-error-for="email"></div>
            </div>

            <div class="col-md-6">
              <label for="phone" class="form-label">Phone Number</label>
              <input type="tel" class="form-control" id="phone" name="phone" placeholder="10 digit number">
              <div class="validation-message" data-error-for="phone"></div>
            </div>

            <div class="col-md-6">
              <label for="age" class="form-label">Age</label>
              <input type="number" class="form-control" id="age" name="age" min="18" max="60" placeholder="18 - 60">
              <div class="validation-message" data-error-for="age"></div>
            </div>

            <div class="col-md-6">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" name="password" placeholder="Create password">
              <div class="strength-track" aria-label="Password strength">
                <span id="strengthFill"></span>
              </div>
              <p class="strength-text" id="strengthText">Password strength: empty</p>
              <div class="validation-message" data-error-for="password"></div>
            </div>

            <div class="col-md-6">
              <label for="confirmPassword" class="form-label">Confirm Password</label>
              <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Repeat password">
              <div class="validation-message" data-error-for="confirmPassword"></div>
            </div>

            <div class="col-md-6">
              <label for="course" class="form-label">Course</label>
              <select class="form-select" id="course" name="course">
                <option value="">Choose a course</option>
                <option value="Frontend Development">Frontend Development</option>
                <option value="Backend Development">Backend Development</option>
                <option value="Full Stack Development">Full Stack Development</option>
                <option value="UI/UX Design">UI/UX Design</option>
              </select>
              <div class="validation-message" data-error-for="course"></div>
            </div>

            <div class="col-md-6">
              <label class="form-label d-block">Gender</label>
              <div class="option-group">
                <label><input type="radio" name="gender" value="Female"> Female</label>
                <label><input type="radio" name="gender" value="Male"> Male</label>
                <label><input type="radio" name="gender" value="Other"> Other</label>
              </div>
              <div class="validation-message" data-error-for="gender"></div>
            </div>

            <div class="col-12">
              <label class="form-label d-block">Skills</label>
              <div class="skills-grid">
                <label><input type="checkbox" name="skills" value="HTML"> HTML</label>
                <label><input type="checkbox" name="skills" value="CSS"> CSS</label>
                <label><input type="checkbox" name="skills" value="JavaScript"> JavaScript</label>
                <label><input type="checkbox" name="skills" value="Node.js"> Node.js</label>
                <label><input type="checkbox" name="skills" value="Express.js"> Express.js</label>
                <label><input type="checkbox" name="skills" value="Bootstrap"> Bootstrap</label>
              </div>
              <div class="validation-message" data-error-for="skills"></div>
              <div class="selected-skills" id="selectedSkills">No skills selected yet.</div>
            </div>

            <div class="col-12">
              <label for="bio" class="form-label">Bio</label>
              <textarea class="form-control" id="bio" name="bio" rows="4" placeholder="Write at least 20 characters about yourself"></textarea>
              <div class="d-flex justify-content-between flex-wrap gap-2">
                <div class="validation-message" data-error-for="bio"></div>
                <small class="char-count" id="bioCount">0 / 20 characters</small>
              </div>
            </div>
          </div>

          <div class="form-actions">
            <a class="btn btn-outline-secondary app-btn-light" href="#/preview">Preview</a>
            <button class="btn btn-primary app-btn" id="submitBtn" type="submit" disabled>Submit Registration</button>
          </div>
        </form>
      </div>
    </section>

    <!-- Preview route -->
    <section class="route-section preview-section section-padding" id="preview" data-route="preview">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-lg-5">
            <span class="section-label">Live Preview</span>
            <h2 class="section-title mt-2">Your profile card updates while you type</h2>
            <p class="section-text">
              The preview and selected skills list are updated with DOM manipulation. The submit button unlocks only when every rule passes.
            </p>
            <a class="btn btn-primary app-btn" href="#/form">Edit Form</a>
          </div>

          <div class="col-lg-7">
            <article class="preview-card" id="previewCard">
              <div class="preview-avatar" id="previewInitials">--</div>
              <div>
                <span class="preview-badge" id="previewCourse">Course not selected</span>
                <h3 id="previewName">Your Name</h3>
                <p id="previewBio">Your bio preview will appear here.</p>
              </div>
              <div class="preview-details">
                <p><strong>Email:</strong> <span id="previewEmail">Not entered</span></p>
                <p><strong>Phone:</strong> <span id="previewPhone">Not entered</span></p>
                <p><strong>Age:</strong> <span id="previewAge">Not entered</span></p>
                <p><strong>Gender:</strong> <span id="previewGender">Not selected</span></p>
              </div>
              <div>
                <strong>Skills</strong>
                <div class="preview-skill-list" id="previewSkills">
                  <span>No skills selected</span>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- Success route -->
    <section class="route-section success-section section-padding" id="success" data-route="success">
      <div class="container">
        <div class="success-card text-center">
          <div class="success-icon">OK</div>
          <h2>Registration submitted successfully</h2>
          <p id="successMessage">Complete the form and submit it to show your success message here.</p>
          <div class="d-flex justify-content-center flex-wrap gap-3">
            <a class="btn btn-primary app-btn" href="#/form">Back to Form</a>
            <a class="btn btn-outline-secondary app-btn-light" href="#/preview">View Preview</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
