<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="layout">
    <section class="panel">
      <p class="eyebrow">Task 2</p>
      <h1>Student Registration Validation</h1>
      <form action="/submit" method="POST" novalidate>
        <label>Name</label>
        <input name="name" value="<%= old.name || '' %>" placeholder="Minimum 3 characters">
        <% if (errors.name) { %><small><%= errors.name %></small><% } %>
        <label>Email</label>
        <input name="email" value="<%= old.email || '' %>" placeholder="student@example.com">
        <% if (errors.email) { %><small><%= errors.email %></small><% } %>
        <label>Age</label>
        <input type="number" name="age" value="<%= old.age || '' %>" placeholder="16 to 60">
        <% if (errors.age) { %><small><%= errors.age %></small><% } %>
        <label>Course</label>
        <select name="course">
          <option value="">Select course</option>
          <% ["Full Stack", "Frontend", "Backend", "Database"].forEach((course) => { %>
            <option value="<%= course %>" <%= old.course === course ? 'selected' : '' %>><%= course %></option>
          <% }) %>
        </select>
        <% if (errors.course) { %><small><%= errors.course %></small><% } %>
        <label>Phone</label>
        <input name="phone" value="<%= old.phone || '' %>" placeholder="9876543210">
        <% if (errors.phone) { %><small><%= errors.phone %></small><% } %>
        <label>Password</label>
        <input type="password" name="password" placeholder="Minimum 6 characters">
        <% if (errors.password) { %><small><%= errors.password %></small><% } %>
        <button type="submit">Validate and Submit</button>
      </form>
    </section>
  </main>
</body>
</html>
