<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="shell">
    <section class="toolbar">
      <div>
        <p class="eyebrow">REST CRUD</p>
        <h1>Task API Dashboard</h1>
      </div>
      <form id="taskForm">
        <input id="title" placeholder="Add a new task">
        <button>Add</button>
      </form>
    </section>
    <p id="message"></p>
    <section id="taskList" class="task-list"></section>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
