<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Task 5 · API Integration</p>
        <h1>My API Task Board</h1>
        <p class="intro">
          This page talks to my Express REST API using JavaScript fetch. Add a task,
          mark it done, or remove it and the list updates without reloading the page.
        </p>
      </div>
      <div class="summary-card">
        <span>Total Tasks</span>
        <strong id="totalCount">0</strong>
      </div>
    </section>

    <section class="workspace">
      <form id="taskForm" class="task-form">
        <label for="title">What do you want to work on?</label>
        <div class="input-row">
          <input id="title" placeholder="Example: Test the update route" autocomplete="off">
          <button type="submit">Add Task</button>
        </div>
        <small>Tip: task titles need at least 3 characters.</small>
      </form>

      <div class="list-header">
        <div>
          <h2>Live Task List</h2>
          <p>Fetched directly from <code>/api/tasks</code>.</p>
        </div>
        <span id="completedCount">0 completed</span>
      </div>

      <p id="message" role="status"></p>
      <section id="taskList" class="task-list" aria-live="polite"></section>
    </section>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
